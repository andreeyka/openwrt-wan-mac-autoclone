#!/bin/sh /etc/rc.common
# procd init script for wan-mac-autoclone.
# In 'arp' mode we run a small polling daemon until a MAC is captured.
# In 'dhcp' mode we just re-apply any stored MAC at boot; the heavy lifting
# is done by the /etc/hotplug.d/dhcp/ hook.

START=19
USE_PROCD=1

PROG=/usr/sbin/wan-mac-autoclone

boot() {
	# Apply startup policy before procd decides whether the ARP poller should run.
	"$PROG" boot 2>/dev/null
	rc_procd start_service
}

start_service() {
	local enabled mode locked

	config_load wan-mac-autoclone
	enabled=$(uci -q get wan-mac-autoclone.global.enabled || echo 1)
	mode=$(uci -q get wan-mac-autoclone.global.mode || echo dhcp)
	locked=$(uci -q get wan-mac-autoclone.state.locked || echo 0)

	[ "$enabled" = "1" ] || return 0
	[ "$mode" = "arp" ] || return 0
	[ "$locked" = "1" ] && return 0

	procd_open_instance "arp-poll"
	procd_set_param command "$PROG" poll
	procd_set_param respawn 3600 5 0
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

service_triggers() {
	procd_add_reload_trigger "wan-mac-autoclone"
}

reload_service() {
	stop
	start
}
